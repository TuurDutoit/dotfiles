<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tuurdutoit.dotfiles.brew-update</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{DOTFILES}}/bin/u</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>10</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>{{HOME}}/Library/Logs/dotfiles-brew-update.log</string>
    <key>StandardErrorPath</key>
    <string>{{HOME}}/Library/Logs/dotfiles-brew-update.log</string>
</dict>
</plist>
