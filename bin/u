#!/bin/sh
#
# u -- update all brew-managed software (at most once per day)

set -u

STAMP="$HOME/Library/Caches/dotfiles-brew-update.stamp"
today=$(date +%Y-%m-%d)

if [ -f "$STAMP" ] && [ "$(cat "$STAMP")" = "$today" ]
then
  echo "=== $(date) — skip, already ran today ==="
  exit 0
fi

if [ -x /opt/homebrew/bin/brew ]
then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]
then
  eval "$(/usr/local/bin/brew shellenv)"
else
  echo "brew not found" >&2
  exit 1
fi

echo "=== $(date) — brew update ==="
brew update

echo "=== $(date) — brew upgrade ==="
brew upgrade

echo "=== $(date) — brew cleanup ==="
brew cleanup

mkdir -p "$(dirname "$STAMP")"
echo "$today" > "$STAMP"

echo "=== $(date) — done ==="
